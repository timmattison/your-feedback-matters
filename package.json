{
  "name": "your-feedback-matters",
  "version": "1.0.0",
  "type": "module",
  "description": "A paper-toss website feedback widget: crumple your feedback into a ball and toss it into a 3D wastebasket. Drop-in React component, GitHub-installable.",
  "keywords": [
    "react",
    "feedback",
    "widget",
    "react-three-fiber",
    "three",
    "component"
  ],
  "homepage": "https://github.com/timmattison/your-feedback-matters#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/timmattison/your-feedback-matters.git"
  },
  "packageManager": "pnpm@11.9.0",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./style.css": "./dist/style.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "./scripts/dev.ts",
    "build": "vite build && tsc -p tsconfig.build.json",
    "build:demo": "pnpm --filter your-feedback-matters-demo build",
    "lint": "oxlint",
    "preview": "pnpm --filter your-feedback-matters-demo preview",
    "test": "vitest run",
    "typecheck": "tsc -b",
    "prepare": "pnpm run build && husky"
  },
  "lint-staged": {
    "*.{ts,tsx,css,md,json}": "prettier --write"
  },
  "peerDependencies": {
    "@react-three/cannon": "^6.6.0",
    "@react-three/fiber": "^9.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "three": ">=0.150.0"
  },
  "dependencies": {
    "html-to-image": "^1.11.13"
  },
  "devDependencies": {
    "@react-three/cannon": "^6.6.0",
    "@react-three/fiber": "^9.6.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.0",
    "@vitejs/plugin-react": "^6.0.3",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "oxlint": "^1.71.0",
    "prettier": "^3.9.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.185.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.9"
  }
}
